# Database (used by Prisma and docker-compose)
DATABASE_URL="postgresql://crm:your_password_here@localhost:5432/customer_relations?schema=public"
DATABASE_URL_READONLY="postgresql://crm_readonly:your_password_here@localhost:5432/customer_relations?schema=public"

# Docker Compose Postgres
POSTGRES_USER=crm
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=customer_relations

# Session signing (HS256 JWT) — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Token encryption for OAuth tokens at rest (32 bytes hex) — generate with same command
TOKEN_ENCRYPTION_KEY=

# Google Gemini AI
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Encrypted backup passphrase
BACKUP_PASSPHRASE=

# CardDAV password — required for CardDAV/vCard sync endpoints
# If not set, all CardDAV requests are rejected
CARDDAV_PASSWORD=

# Email — Resend (https://resend.com)
# If not set, all emails are logged to console instead of sent
RESEND_API_KEY=
EMAIL_FROM=Customer Relations <noreply@example.com>
PRACTICE_NAME=Customer Relations
ADMIN_EMAIL=
PORTAL_URL=http://localhost:3000/portal

# Audit alerts — cron job recipient (scripts/audit-alerts.ts)
ALERT_EMAIL=
